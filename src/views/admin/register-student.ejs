<%- include('../partials/head', { title, user }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3 mb-0">Team Thota - Register Student</h1>
  <a class="btn btn-outline-primary" href="/admin/dashboard">Back to Dashboard</a>
</div>

<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/admin/register-student" method="POST" class="d-grid gap-3">
          <div>
            <label class="form-label">Student Name</label>
            <input class="form-control" name="name" required />
          </div>
          <div>
            <label class="form-label">Contact</label>
            <input class="form-control" name="contact" />
          </div>
          <div>
            <label class="form-label">Email</label>
            <input class="form-control" name="email" type="email" required />
          </div>
          <div>
            <label class="form-label">Event Name</label>
            <select class="form-select" name="eventName" required>
              <option value="">Choose event</option>
              <% events.forEach((event) => { %>
                <option value="<%= event.Event_Name %>"><%= event.Event_Name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="form-label">Team Name</label>
            <input class="form-control" name="teamName" required />
          </div>
          <div>
            <label class="form-label">Team Members List</label>
            <textarea class="form-control" name="teamMembers" rows="3" placeholder="Enter member names separated by commas"></textarea>
          </div>
          <button class="btn btn-primary">Register + Generate QR</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body text-center">
        <h2 class="h5 mb-3">Generated QR</h2>
        <% if (generatedQr) { %>
          <img src="<%= generatedQr %>" alt="QR" class="img-fluid qr-preview" />
          <div class="mt-3">
            <a href="<%= generatedQr %>" download="student_qr.png" class="btn btn-success">Download PNG</a>
          </div>
          <p class="small text-muted mt-2">QR String: <%= qrString %></p>
        <% } else { %>
          <p class="text-muted">QR will appear after student registration.</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
