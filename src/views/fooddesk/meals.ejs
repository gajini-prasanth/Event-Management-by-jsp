<%- include('../partials/head', { title, user }) %>

<h1 class="h3 mb-3">Food Desk Meal Tracker</h1>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <form action="/fooddesk/meals" method="GET" class="row g-2 align-items-end">
      <div class="col-md-8">
        <label class="form-label mb-1">Search Team</label>
        <input
          type="text"
          name="search"
          class="form-control"
          placeholder="Type team name..."
          value="<%= search || '' %>"
        />
      </div>
      <div class="col-md-4 d-flex gap-2">
        <button class="btn btn-primary">Search</button>
        <a href="/fooddesk/meals" class="btn btn-outline-secondary">Clear</a>
      </div>
    </form>
  </div>
</div>

<% if (selectedTeam) { %>
  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">Team Members: <%= selectedTeam %></h2>
        <a href="/fooddesk/meals?<%= search ? `search=${encodeURIComponent(search)}` : '' %>" class="btn btn-sm btn-outline-secondary">Close</a>
      </div>
      <% if (selectedTeamMembers && selectedTeamMembers.length > 0) { %>
        <ul class="mb-0">
          <% selectedTeamMembers.forEach((member) => { %>
            <li><%= member %></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="text-muted mb-0">No members found for this team yet.</p>
      <% } %>
    </div>
  </div>
<% } %>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Team Name</th>
            <th>Morning Snacks</th>
            <th>Lunch</th>
            <th>Evening Snacks</th>
            <th>Final Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% if (rows.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4">No team found for current search.</td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <tr>
              <form action="/fooddesk/meals/update" method="POST">
                <input type="hidden" name="id" value="<%= row.ID %>" />
                <input type="hidden" name="search" value="<%= search || '' %>" />
                <input type="hidden" name="team" value="<%= selectedTeam || '' %>" />
                <td>
                  <strong>
                    <a href="/fooddesk/meals?search=<%= encodeURIComponent(search || '') %>&team=<%= encodeURIComponent(row.Team_Name || '') %>">
                      <%= row.Team_Name %>
                    </a>
                  </strong>
                  <div class="small text-muted">
                    Required:
                    <%= row.required_morning_snacks ? 'M' : '' %>
                    <%= row.required_lunch ? ' L' : '' %>
                    <%= row.required_evening_snacks ? ' E' : '' %>
                  </div>
                </td>
                <td><input type="checkbox" name="morning" <%= row.Morning_Snacks ? 'checked' : '' %> /></td>
                <td><input type="checkbox" name="lunch" <%= row.Lunch ? 'checked' : '' %> /></td>
                <td><input type="checkbox" name="evening" <%= row.Evening_Snacks ? 'checked' : '' %> /></td>
                <td>
                  <% if (row.Final_Status) { %>
                    <span class="badge text-bg-success">Completed</span>
                  <% } else { %>
                    <span class="badge text-bg-warning">Pending</span>
                  <% } %>
                </td>
                <td><button class="btn btn-sm btn-primary">Save</button></td>
              </form>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
